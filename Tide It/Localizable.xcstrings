    "Au bout de 30 jours, l'app repasse en gratuit — tu gardes les marées du monde entier, tes favoris et l'Apple Watch." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nach 30 Tagen wird die App wieder kostenlos — du behältst die Gezeiten weltweit, deine Favoriten und die Apple Watch."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "After 30 days, the app goes back to free — you keep tides worldwide, your favorites and the Apple Watch."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tras 30 días, la app vuelve a ser gratuita — conservas las mareas de todo el mundo, tus favoritos y el Apple Watch."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Au bout de 30 jours, l'app repasse en gratuit — tu gardes les marées du monde entier, tes favoris et l'Apple Watch."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30 दिन बाद ऐप फिर मुफ़्त हो जाता है — आपके पास दुनियाभर के ज्वार-भाटे, पसंदीदा और Apple Watch बने रहते हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dopo 30 giorni l'app torna gratuita — mantieni le maree di tutto il mondo, i tuoi preferiti e l'Apple Watch."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30日後、アプリは無料版に戻ります — 世界中の潮汐、お気に入り、Apple Watchはそのまま使えます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30일 후 앱은 무료로 돌아가요 — 전 세계 조석, 즐겨찾기, Apple Watch는 그대로 유지돼요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Na 30 dagen wordt de app weer gratis — je houdt de getijden wereldwijd, je favorieten en de Apple Watch."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ao fim de 30 dias, a app volta a ser gratuita — ficas com as marés do mundo inteiro, os teus favoritos e o Apple Watch."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30 天后应用将恢复免费版——你仍可使用全球潮汐、收藏和 Apple Watch。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30 天後，App 會回到免費版——你仍保有全球潮汐、收藏與 Apple Watch。"
          }
        }
      }
    },

    "Ajuste la courbe et les fenêtres GO selon le vent réellement mesuré près de toi, quand une station proche est fiable." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passt die Kurve und die GO-Fenster an den real gemessenen Wind in deiner Nähe an, sobald eine Station in der Nähe zuverlässig ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adjusts the curve and GO windows to the wind actually measured near you, when a nearby station is reliable."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajusta la curva y las ventanas GO al viento realmente medido cerca de ti, cuando una estación cercana es fiable."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajuste la courbe et les fenêtres GO selon le vent réellement mesuré près de toi, quand une station proche est fiable."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जब पास का कोई स्टेशन भरोसेमंद हो, तो कर्व और GO विंडो को आपके पास वास्तव में मापी गई हवा के हिसाब से एडजस्ट करता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adatta la curva e le finestre GO al vento realmente misurato vicino a te, quando una stazione vicina è affidabile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "近くの観測所が信頼できるとき、実測した風に合わせてカーブとベストタイミングを補正します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "근처에 신뢰할 만한 관측소가 있을 때, 실제로 측정된 바람에 맞춰 곡선과 출발 윈도우를 조정해요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Past de curve en GO-momenten aan op de wind die echt bij jou in de buurt wordt gemeten, als een station in de buurt betrouwbaar is."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajusta a curva e as janelas GO ao vento realmente medido perto de ti, quando uma estação próxima é fiável."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当附近有可靠监测站时，根据你身边实测的风来调整曲线和出航窗口。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "當附近有可靠的觀測站時，依你身邊實際測得的風來調整曲線與出發時機。"
          }
        }
      }
    },

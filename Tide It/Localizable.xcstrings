    "Profite-en encore quelques jours. Ensuite, le Premium passe sur abonnement — tu pourras continuer quand tu veux." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Genieße es noch ein paar Tage. Danach läuft Premium per Abo — du kannst jederzeit weitermachen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enjoy it a few more days. After that, Premium moves to subscription — you can continue whenever you like."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disfrútalo unos días más. Después, el Premium pasa a suscripción — puedes continuar cuando quieras."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profite-en encore quelques jours. Ensuite, le Premium passe sur abonnement — tu pourras continuer quand tu veux."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कुछ और दिन एंजॉय करें। उसके बाद Premium सदस्यता पर चला जाता है — जब चाहें जारी रख सकते हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Goditelo ancora qualche giorno. Poi il Premium passa in abbonamento — puoi continuare quando vuoi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あと数日楽しんでください。その後、プレミアムはサブスクリプションに移行します — いつでも続けられます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "며칠 더 즐기세요. 이후 프리미엄은 구독으로 전환돼요 — 원할 때 언제든 이어갈 수 있어요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geniet er nog een paar dagen van. Daarna gaat Premium via een abonnement — je kunt doorgaan wanneer je wilt."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aproveita mais uns dias. Depois, o Premium passa a subscrição — podes continuar quando quiseres."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "再尽享几天。之后高级会员将转为订阅制——你可随时继续。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "再多享用幾天。之後 Premium 將改為訂閱制——你可以隨時繼續。"
          }
        }
      }
    },

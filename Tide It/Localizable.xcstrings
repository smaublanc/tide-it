    "Sorties Parfaites quand le vent et la marée s'alignent, et tes alertes perso pour ne rien rater." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perfekte Sessions, wenn Wind und Gezeiten zusammenpassen, plus deine eigenen Alerts, damit du nichts verpasst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perfect Sessions when wind and tide align, plus your custom alerts so you never miss out."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salidas Perfectas cuando el viento y la marea se alinean, y tus alertas personales para no perderte nada."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जब हवा और ज्वार-भाटा मिलते हैं तब परफेक्ट सेशन, और कुछ न छूटे इसके लिए आपके कस्टम अलर्ट।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sessioni Perfette quando vento e marea si allineano, più i tuoi avvisi personalizzati per non perderti nulla."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "風と潮が揃ったときのベストセッション、さらに見逃さないためのカスタムアラート。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "바람과 조석이 맞을 때의 완벽한 출발, 그리고 빠짐없이 챙기는 맞춤 알림."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perfecte sessies wanneer wind en getij samenvallen, plus je eigen alerts zodat je niets mist."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sessões Perfeitas quando o vento e a maré se alinham, mais os teus alertas personalizados para não perderes nada."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "风与潮汐对上时的完美出航，加上你的自定义提醒，让你绝不错过。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "風與潮汐對齊時的完美出擊，加上你的自訂提醒，絕不錯過。"
          }
        }
      }
    },
    "Sorties Parfaites quand le vent et la marée s'alignent, grandes marées pour la pêche à pied, et tes alertes perso." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perfekte Ausfahrten, wenn Wind und Gezeiten passen, Springtiden fürs Wattangeln und deine eigenen Hinweise."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perfect Outings when wind and tide align, spring tides for shellfishing, and your custom alerts."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salidas Perfectas cuando el viento y la marea se alinean, grandes mareas para el marisqueo y tus alertas personalizadas."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जब हवा और ज्वार-भाटा मिलते हैं तब परफेक्ट सेशन, तट संग्रह के लिए बड़ी ज्वार, और आपके कस्टम अलर्ट।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uscite Perfette quando vento e marea si allineano, grandi maree per la pesca a piedi e i tuoi avvisi personalizzati."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "風と潮が揃ったときのベストセッション、潮干狩り向けの大潮、そしてカスタムアラート。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "바람과 조석이 맞을 때의 완벽한 출발, 갯벌 채집을 위한 대조, 그리고 맞춤 알림."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perfecte sessies wanneer wind en getij samenvallen, springtijen voor het wadlopen, en je eigen alerts."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sessões Perfeitas quando o vento e a maré se alinham, marés vivas para a pesca à linha na costa e os teus alertas personalizados."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "风与潮汐对上时的完美出航、用于赶海的大潮，以及你的自定义提醒。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "風與潮汐對齊時的完美出擊、適合潮間帶採集的大潮，以及你的自訂提醒。"
          }
        }
      }
    },

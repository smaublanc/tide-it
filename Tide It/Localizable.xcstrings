    "Gratuit : crée tes activités et tes alertes, aperçu flouté du calendrier GO, marées hors-ligne dans le monde entier.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Free: create your activities and alerts, blurred preview of the GO calendar, offline tides worldwide."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kostenlos: erstelle deine Aktivitäten und Alarme, verschwommene Vorschau des GO-Kalenders, weltweite Gezeiten offline."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gratis: crea tus actividades y tus alertas, vista previa difuminada del calendario GO, mareas sin conexión en todo el mundo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gratis: crea le tue attività e le tue sveglie, anteprima sfocata del calendario GO, maree offline in tutto il mondo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gratis: maak je activiteiten en waarschuwingen, vervaagd voorbeeld van de GO-kalender, getij wereldwijd offline."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Grátis: cria as tuas atividades e os teus alertas, pré-visualização desfocada do calendário GO, marés offline no mundo inteiro."
          }
        }
      }
    },

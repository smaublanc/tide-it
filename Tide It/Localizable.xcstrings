    "Les grandes marées (coefficient ≥ 90) seront automatiquement enregistrées lorsque vous consultez les marées d'un port." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Springtiden (Koeffizient ≥ 90) werden automatisch gespeichert, wenn Sie die Tiden eines Hafens ansehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spring tides (coefficient ≥ 90) are saved automatically when you view a port's tides."
          }

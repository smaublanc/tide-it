    "M'alerter quand TOUS mes spots alignent vent + eau + météo pour mes activités, où que je sois." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benachrichtige mich, wenn an EINEM meiner Spots Wind + Wasser + Wetter für meine Aktivitäten passen, egal wo ich bin."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alert me when ANY of my spots lines up wind + water + weather for my activities, wherever I am."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avísame cuando CUALQUIERA de mis spots alinee viento + agua + tiempo para mis actividades, esté donde esté."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "मुझे अलर्ट करो जब मेरा कोई भी स्पॉट मेरी गतिविधियों के लिए हवा + पानी + मौसम को एक साथ ला दे, मैं चाहे कहीं भी रहूँ।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avvisami quando UNO QUALSIASI dei miei spot allinea vento + acqua + meteo per le mie attività, ovunque io sia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "どこにいても、お気に入りスポットのいずれかで風＋水位＋天気がアクティビティに揃ったらアラートします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "어디에 있든, 내 스폿 중 한 곳이라도 바람 + 수위 + 날씨가 내 액티비티에 맞으면 알려주세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Waarschuw me wanneer een van mijn spots wind + water + weer op één lijn brengt voor mijn activiteiten, waar ik ook ben."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avisar-me quando QUALQUER um dos meus spots alinhar vento + água + tempo para as minhas atividades, onde quer que esteja."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当我的任一浪点风、水位、天气都对上我的活动时提醒我，无论我身在何处。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "當我的任一浪點的風＋水位＋天氣都符合我的活動時通知我，無論我在哪裡。"
          }
        }
      }
    },
    "Ma plage praticable" : {

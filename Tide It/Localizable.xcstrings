    "Autorisez la localisation pour trouver automatiquement les ports près de vous et obtenir la météo locale." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erlauben Sie die Ortung, um automatisch Häfen in Ihrer Nähe zu finden und lokales Wetter zu erhalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allow location to automatically find nearby ports and get local weather."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permite la ubicación para encontrar automáticamente puertos cercanos y obtener el tiempo local."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autorisez la localisation pour trouver automatiquement les ports près de vous et obtenir la météo locale."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "पास के पोर्ट अपने-आप ढूँढने और स्थानीय मौसम पाने के लिए लोकेशन की अनुमति दें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consenti la posizione per trovare automaticamente i porti vicini e ottenere il meteo locale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置情報を許可すると、近くの港を自動で見つけて現地の天気を取得できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "위치를 허용하면 근처 항구를 자동으로 찾고 현지 날씨를 받아볼 수 있어요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sta locatie toe om automatisch havens in je buurt te vinden en het lokale weer op te halen."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permite a localização para encontrar automaticamente os portos perto de ti e obter a meteorologia local."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "允许定位，自动找到你附近的港口并获取当地天气。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "允許定位以自動尋找你附近的港口並取得當地天氣。"
          }
        }
      }
    },

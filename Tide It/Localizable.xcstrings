    "Sans condition, ce sport ne s'affichera pas. Ajoute au moins une plage de vent." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ohne Bedingung wird diese Sportart nicht angezeigt. Füge mindestens eine Windspanne hinzu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Without a condition, this sport won't show. Add at least a wind range."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sin condición, este sport no se mostrará. Añade al menos un rango de viento."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "शर्त के बिना यह स्पोर्ट नहीं दिखेगा। कम से कम एक हवा की रेंज जोड़ें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Senza una condizione, questo sport non comparirà. Aggiungi almeno un range di vento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "条件がないとこの種目は表示されません。少なくとも風の範囲を1つ追加してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "조건이 없으면 이 스포츠는 표시되지 않아요. 바람 범위를 하나 이상 추가하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zonder voorwaarde wordt deze sport niet getoond. Voeg minstens een windbereik toe."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sem condição, este desporto não aparece. Adiciona pelo menos um intervalo de vento."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "没有条件，此运动将不会显示。请至少添加一个风速范围。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "沒有條件，這項運動就不會顯示。至少新增一個風速範圍。"
          }
        }
      }
    },
    "Score %lld sur 100, %@" : {
      "extractionState" : "manual",

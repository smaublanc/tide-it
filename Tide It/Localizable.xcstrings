          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prueba gratis de una semana — sin compromiso, cancelable en cualquier momento."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "एक हफ़्ते का मुफ़्त ट्रायल — कोई बंधन नहीं, कभी भी रद्द करें।"

          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Spot the best low tides, your exposed-foreshore window and when the water returns."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Detecta las mejores bajamares, tu ventana de costa descubierta y la hora de regreso del agua."

            "value" : "बड़ी ज्वार (गुणांक ≥ 90) तब अपने-आप सहेजी जाती हैं जब आप किसी पोर्ट के ज्वार-भाटे देखते हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",

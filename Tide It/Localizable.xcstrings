    "Autorisez la localisation pour trouver automatiquement les ports près de vous et obtenir la météo locale.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlauben Sie die Ortung, um automatisch Häfen in Ihrer Nähe zu finden und lokales Wetter zu erhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow location to automatically find nearby ports and get local weather."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permite la ubicación para encontrar automáticamente puertos cercanos y obtener el tiempo local."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorisez la localisation pour trouver automatiquement les ports près de vous et obtenir la météo locale."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",

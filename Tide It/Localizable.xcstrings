    "Le moteur harmonique n'a pas assez de données pour ce port. Consultez d'abord les marées du jour pour calibrer les prédictions.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die harmonische Engine hat nicht genügend Daten für diesen Hafen. Sehen Sie sich zuerst die heutigen Tiden an, um die Vorhersagen zu kalibrieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The harmonic engine doesn't have enough data for this port. Check today's tides first to calibrate predictions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El motor armónico no tiene suficientes datos para este puerto. Consulta primero las mareas del día para calibrar las predicciones."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il motore armonico non ha dati sufficienti per questo porto. Consulta prima le maree del giorno per calibrare le previsioni."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",

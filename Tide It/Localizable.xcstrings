    "Repérez les meilleures basses mers, votre fenêtre d'estran découvert et l'heure de retour de l'eau." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finden Sie die besten Niedrigwasser, Ihr Zeitfenster für das freiliegende Watt und die Rückkehr des Wassers."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spot the best low tides, your exposed-foreshore window and when the water returns."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Detecta las mejores bajamares, tu ventana de costa descubierta y la hora de regreso del agua."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सबसे अच्छे भाटे, खुले तट की अपनी विंडो और पानी लौटने का समय पहचानें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Individua le migliori basse maree, la tua finestra di costa scoperta e l'ora di ritorno dell'acqua."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ベストな干潮、干潟が出るウィンドウ、水が戻る時刻を見つけましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "최적의 간조, 드러난 갯벌 윈도우, 물이 돌아오는 시각을 확인하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spot de beste laagwaters, je venster met droge wadbodem en wanneer het water terugkomt."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Identifica as melhores baixa-mares, a tua janela de estran descoberto e a hora de regresso da água."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "找出最佳低潮、你的露滩窗口以及涨水回归的时间。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "找出最佳乾潮、你的露灘時段，以及海水回漲的時間。"
          }
        }
      }

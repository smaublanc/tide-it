    "Votre compagnon marées pour 3 500+ ports dans le monde.\nHoraires, coefficients, météo et activités nautiques.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr Tiden-Begleiter für 3.500+ Häfen weltweit.\nTidenzeiten, Koeffizienten, Wetter und Wassersport."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your tide companion for 3,500+ ports worldwide.\nTide times, coefficients, weather and water activities."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu compañero de mareas para más de 3.500 puertos en el mundo.\nHorarios, coeficientes, tiempo y actividades náuticas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo compagno di maree per oltre 3.500 porti nel mondo.\nOrari, coefficienti, meteo e attività nautiche."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je getijmaatje voor 3.500+ havens wereldwijd.\nGetijtijden, getijcoëfficiënten, weer en wateractiviteiten."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O teu companheiro de marés para mais de 3 500 portos no mundo.\nHorários, coeficientes, meteorologia e atividades náuticas."
          }
        }
      }
    },

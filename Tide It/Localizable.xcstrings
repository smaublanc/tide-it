    "Essai gratuit d'une semaine — sans engagement, annulable à tout moment." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Woche kostenlos testen — unverbindlich, jederzeit kündbar."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",

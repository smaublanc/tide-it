    "Les fenêtres GO s'allument quand le vent prévu reste dans ta plage, de jour.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "GO windows light up when the forecast wind stays in your range, in daylight."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "GO-Fenster leuchten auf, wenn der prognostizierte Wind tagsüber in deiner Spanne bleibt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las ventanas GO se encienden cuando el viento previsto se mantiene en tu rango, de día."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le finestre GO si accendono quando il vento previsto resta nel tuo range, di giorno."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "GO-vensters lichten op zodra de voorspelde wind binnen jouw bereik blijft, overdag."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As janelas GO acendem-se quando o vento previsto fica dentro da tua faixa, de dia."
          }
        }
      }
    },
    "Les fenêtres suivent la météo et tes réglages — touche pour ajuster tes sports.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Windows follow the weather and your settings — tap to adjust your sports."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Fenster richten sich nach Wetter und deinen Einstellungen — tippe, um deine Sportarten anzupassen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las ventanas siguen el tiempo y tus ajustes — toca para ajustar tus sports."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le finestre seguono il meteo e le tue impostazioni — tocca per regolare i tuoi sport."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De vensters volgen het weer en je instellingen — tik om je sporten aan te passen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As janelas seguem o tempo e as tuas definições — toca para ajustar os teus desportos."
          }
        }
      }
    },

    "Ton plancher de vent (selon ton quiver). Sert à juger tes sorties kite/wing." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Mindestwind (je nach Quiver). Bewertet deine Kite-/Wing-Sessions."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your minimum wind (based on your quiver). Used to rate your kite/wing sessions."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu viento mínimo (según tu quiver). Sirve para evaluar tus sesiones de kite/wing."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपकी न्यूनतम हवा (आपके quiver के अनुसार)। आपके kite/wing सेशन आंकने में काम आती है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tuo vento minimo (in base al quiver). Serve a valutare le tue sessioni kite/wing."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたの最低風速（手持ちのギアに応じて）。カイト／ウイングのセッション評価に使います。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신의 최소 바람 (장비 기준). 카이트/윙 출발을 평가하는 데 쓰여요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je minimumwind (op basis van je quiver). Voor het beoordelen van je kite/wing-sessies."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O teu mínimo de vento (consoante o teu equipamento). Serve para avaliar as tuas sessões de kite/wing."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的最低风力（取决于你的装备）。用于评估你的风筝/wing 出航。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的最低風速（依你的裝備）。用來評估你的風箏／wing 出擊。"
          }
        }
      }
    },

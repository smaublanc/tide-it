    "Choisis ce que tu pratiques : on te trouvera la prochaine fenêtre parfaite, au bon endroit et au bon moment.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle deine Aktivitäten – wir finden dein nächstes perfektes Fenster, am richtigen Ort und zur richtigen Zeit."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose what you do — we'll find your next perfect window, at the right place and time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige lo que practicas: encontraremos tu próxima ventana perfecta, en el lugar y momento ideales."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli cosa pratichi: troveremo la tua prossima finestra perfetta, nel posto e nel momento giusti."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies wat je doet: we vinden je volgende perfecte venster, op de juiste plek en het juiste moment."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolhe o que praticas: encontramos-te a próxima janela perfeita, no sítio e no momento certos."
          }
        }
      }
    },

      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Richtung, in die sich das Wasser öffnet – erkennt ablandigen Wind (gefährlich beim Kite/Wing)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Direction the water opens toward — used to flag offshore wind (dangerous for kite/wing)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dirección hacia la que se abre el agua: sirve para detectar el viento de tierra (peligroso en kite/wing)."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जिस ओर पानी खुलता है — ऑफ़शोर हवा (kite/wing में खतरनाक) को पहचानने में काम आता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Direzione verso cui si apre l'acqua: serve a rilevare il vento da terra (pericoloso in kite/wing)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "水面が開ける方向 — 沖向きの風（カイト／ウイングで危険）を見極めるのに使います。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "수면이 열린 방향 — 육풍(카이트/윙에 위험)을 표시하는 데 쓰여요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Richting waarin het water opent — om aflandige wind te herkennen (gevaarlijk bij kite/wing)."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Direção para onde a água se abre — serve para sinalizar o vento de terra (perigoso em kite/wing)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "水域朝向——用于标记离岸风（风筝/wing 冲浪危险）。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "水域開口朝向的方向——用來判別離岸風（風箏／wing 危險）。"
          }
        }
      }
    },
    "Donne l'heure et la hauteur de la prochaine marée haute ou basse." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",

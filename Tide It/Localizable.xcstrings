    "On compare la prévision au vent réel mesuré pour révéler le biais local" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir vergleichen die Vorhersage mit dem real gemessenen Wind, um den lokalen Bias aufzudecken"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We compare the forecast to real measured wind to reveal the local bias"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comparamos la previsión con el viento real medido para revelar el sesgo local"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "On compare la prévision au vent réel mesuré pour révéler le biais local"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "स्थानीय पूर्वाग्रह जानने के लिए हम पूर्वानुमान की तुलना वास्तविक मापी गई हवा से करते हैं"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confrontiamo la previsione con il vento reale misurato per svelare lo scarto locale"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "予報と実測した風を比べて、その土地のクセを明らかにします"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "예보와 실측 바람을 비교해 지역 편차를 드러내요"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We vergelijken de voorspelling met de echt gemeten wind om de lokale afwijking te tonen"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comparamos a previsão com o vento real medido para revelar o desvio local"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们将预报与实测风对比，揭示当地偏差"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我們將預報與實測風比對，揭示當地偏差"
          }
        }
      }
    },
    "On t'alerte à l'avance dès qu'une fenêtre idéale approche, sans ouvrir l'app. 1 alerte offerte par mois, illimité en premium." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir benachrichtigen dich vorab, wenn ein ideales Fenster naht – ohne die App zu öffnen. 1 kostenloser Hinweis pro Monat, unbegrenzt mit Premium."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We alert you ahead of time when an ideal window approaches, without opening the app. 1 free alert per month, unlimited with premium."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Te avisamos con antelación cuando se acerca una ventana ideal, sin abrir la app. 1 alerta gratis al mes, ilimitadas con premium."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ऐप खोले बिना ही, जब कोई परफेक्ट विंडो पास आती है तो हम आपको पहले से अलर्ट कर देते हैं। हर महीने 1 अलर्ट मुफ़्त, premium में असीमित।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ti avvisiamo in anticipo quando si avvicina una finestra ideale, senza aprire l'app. 1 avviso gratis al mese, illimitati con premium."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "理想的なウィンドウが近づくと、アプリを開かなくても事前にお知らせします。無料は月1回、プレミアムで無制限。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이상적인 윈도우가 다가오면 앱을 열지 않아도 미리 알려드려요. 무료는 월 1회, 프리미엄은 무제한이에요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We waarschuwen je vooraf zodra een ideaal venster nadert, zonder de app te openen. 1 gratis alert per maand, onbeperkt met premium."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avisamos-te com antecedência assim que uma janela ideal se aproxima, sem abrires a app. 1 alerta grátis por mês, ilimitado em premium."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "理想窗口临近时，我们会提前提醒你，无需打开应用。每月赠送 1 个提醒，高级会员无限量。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "理想時機接近時，我們會提前提醒你，無需開啟 App。每月免費 1 則提醒，Premium 可無限制。"
          }
        }
      }
    },
